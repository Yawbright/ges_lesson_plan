# Supabase project — fill these in and copy to .env (or set in EAS secrets)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional local development only. Hosted parsing goes through Supabase Edge Functions.
EXPO_PUBLIC_USE_LOCAL_AI=false
EXPO_PUBLIC_LOCAL_AI_URL=http://localhost:8787

# Server-only (Supabase Edge Function secrets — DO NOT prefix with EXPO_PUBLIC)
ANTHROPIC_API_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=
PARSER_SERVICE_URL=
PARSER_BACKEND=
PARSER_RENDER_SERVICE_URL=
PARSER_CLOUD_RUN_SERVICE_URL=
DEV_CREDIT_GRANT_SECRET=
