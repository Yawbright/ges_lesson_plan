{
  "expo": {
    "name": "Ghana Lesson Planner",
    "slug": "ghana-lesson-planner",
    "scheme": "ghlessonplanner",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghanalessonplanner.app"
    },
    "android": {
      "package": "com.ghanalessonplanner.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
