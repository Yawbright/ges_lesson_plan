{
  "expo": {
    "name": "Ghana Lesson Planner",
    "slug": "ghana-lesson-planner",
    "scheme": "ghlessonplanner",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghanalessonplanner.app"
    },
    "android": {
      "package": "com.ghanalessonplanner.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F4C3A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./public/favicon.png",
      "name": "Ghana Lesson Planner",
      "shortName": "GES Planner"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
